@using CSharp_Themed_Events.Enums
@model IEnumerable<CSharp_Themed_Events.Models.Event>

<div class="container">
    
    <div class="row">
        <div class="col s12">
            <div class="card-panel">
                <h5 class="deep-purple-text"><i class="material-icons left">filter_list</i> Filters</h5>
                <form asp-controller="Gallery" asp-action="Gallery" method="get">
                    <div class="row" style="margin-bottom: 0;">
                        <input class="datepicker" type="text" name="startDate" id="startDate" value="@ViewData["StartDate"]">
                        <label for="startDate">Since</label>

                        <input class="datepicker" type="text" name="endDate" id="endDate" value="@ViewData["EndDate"]">
                        <label for="endDate">Until</label>

                        <select name="status">
                            <option value="0" selected="@(ViewData["CurrentStatus"]?.ToString() == "0")">All status</option>
                            <option value="1" selected="@(ViewData["CurrentStatus"]?.ToString() == "1")">Coming Soon</option>
                            <option value="2" selected="@(ViewData["CurrentStatus"]?.ToString() == "2")">On Going</option>
                            <option value="3" selected="@(ViewData["CurrentStatus"]?.ToString() == "3")">Finished</option>
                        </select>
                        <label>Status</label>

                        <div class="input-field col s12 m3 center-align">
                            <button type="submit" class="btn deep-purple waves-effect">
                                Filter
                            </button>
                            <a asp-action="Gallery" class="btn-flat waves-effect grey-text">Clear</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col s12 m6 l4">
                    <div class="card hoverable gallery-card">

                        <div class="card-image">
                            @if (!string.IsNullOrEmpty(item.ImgURL))
                            {
                                <img src="@item.ImgURL" class="gallery-img">
                            }
                            else
                            {
                                <img src="https://via.placeholder.com/400x200?text=Sin+Imagen" class="gallery-img">
                            }

                            <span class="btn-floating halfway-fab waves-effect waves-light @GetStatusColor(item.Status)">
                                <i class="material-icons">@GetStatusIcon(item.Status)</i>
                            </span>
                        </div>

                        <div class="card-content" style="flex-grow: 1;">
                            <span class="card-title grey-text text-darken-4 truncate" title="@item.Name">
                                @item.Name
                            </span>
                            <p><i class="material-icons tiny">place</i> @item.Location</p>
                            <p><i class="material-icons tiny">event</i> @item.Date.ToShortDateString()</p>
                        </div>

                        <div class="card-action">
                            <span class="right grey-text" style="font-size: 0.8rem;">@item.Status</span>
                            <div class="card-action">
                                <button class="btn-flat waves-effect deep-purple-text text-darken-1 btn-view-details" 
                                        data-name="@item.Name"
                                        data-date="@item.Date.ToShortDateString()"
                                        data-desc="@item.Description"
                                        data-loc="@item.Location"
                                        data-img="@item.ImgURL"
                                        data-status="@item.Status">
                                    Details
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<div id="modalDetails" class="modal modal-fixed-footer">
    <div class="modal-content">
        <div class="row">
            <div class="col s12 m5">
                <img id="modalImg" src="" alt="" class="responsive-img z-depth-1" style="border-radius: 8px;">
            </div>
            <div class="col s12 m7">
                <h4 id="modalName" class="deep-purple-text text-darken-3" style="font-weight: bold; margin-top: 0;"></h4>
                <div class="divider"></div>
                <p><strong><i class="material-icons tiny">event</i> Fecha:</strong> <span id="modalDate"></span></p>
                <p><strong><i class="material-icons tiny">place</i> Ubicación:</strong> <span id="modalLocation"></span></p>
                <p><strong><i class="material-icons tiny">info</i> Estado:</strong> <span id="modalStatus" class="badge-status"></span></p>
                <div class="section">
                    <h6 style="font-weight: bold;">Descripción:</h6>
                    <p id="modalDescription" class="grey-text text-darken-2"></p>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <a href="#!" class="modal-close waves-effect btn-flat">Cerrar</a>
    </div>
</div>

@functions {
    // Helpers para la lógica visual del Enum
    public string GetStatusColor(EventStatus status) => status switch {
        EventStatus.ComingSoon => "blue",
        EventStatus.OnGoing => "green",
        EventStatus.Finished => "grey",
        _ => "deep-purple"
    };

    public string GetStatusIcon(EventStatus status) => status switch {
        EventStatus.ComingSoon => "schedule",
        EventStatus.OnGoing => "play_arrow",
        EventStatus.Finished => "check",
        _ => "help"
    };
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            var elems = document.querySelectorAll('select');
            M.FormSelect.init(elems);
            
            M.Datepicker.init(document.querySelectorAll('.datepicker'));
        });

        document.addEventListener('DOMContentLoaded', function() {
            // 1. Inicializar el Modal
            var modalElem = document.querySelector('#modalDetails');
            var modalInstance = M.Modal.init(modalElem);

            // 2. Manejar el click en "Ver detalles"
            document.querySelectorAll('.btn-view-details').forEach(btn => {
                btn.addEventListener('click', function() {
                    // Extraer datos del botón
                    const name = this.getAttribute('data-name');
                    const date = this.getAttribute('data-date');
                    const desc = this.getAttribute('data-desc');
                    const loc = this.getAttribute('data-loc');
                    const img = this.getAttribute('data-img') || 'https://via.placeholder.com/400x300?text=No+Image';
                    const status = this.getAttribute('data-status');

                    // Inyectar datos en el modal
                    document.getElementById('modalName').innerText = name;
                    document.getElementById('modalDate').innerText = date;
                    document.getElementById('modalDescription').innerText = desc;
                    document.getElementById('modalLocation').innerText = loc;
                    document.getElementById('modalImg').src = img;

                    // Ajustar el badge del estado (opcional: podrías añadir clases de color aquí)
                    const statusBadge = document.getElementById('modalStatus');
                    statusBadge.innerText = status;

                    // 3. Abrir el modal
                    modalInstance.open();
                });
            });
        });
    </script>
}